OMEGA_EMBEDDING_BACKEND=gemini
OMEGA_GEMINI_API_KEY=key
OMEGA_EMBED_MODEL=gemini-embedding-001
# Optional override:
# OMEGA_GEMINI_BASE_URL=https://generativelanguage.googleapis.com

# Phase 4 (optional)
OMEGA_PHASE4_BACKEND=gemini
# Stable Flash-Lite = lowest-cost generation tier for summaries
OMEGA_PHASE4_MODEL=gemini-2.5-flash-lite
OMEGA_PHASE4_MAX_INPUT_CHARS=48000