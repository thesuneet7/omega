# Google Gemini (embeddings + summaries) — get a key at https://aistudio.google.com/apikey
OMEGA_GEMINI_API_KEY=your-api-key-here
OMEGA_GEMINI_BASE_URL=https://generativelanguage.googleapis.com

# Phase 2 — embeddings (default: Gemini text embedding model)
OMEGA_EMBEDDING_BACKEND=gemini
OMEGA_EMBED_MODEL=gemini-embedding-001

# Phase 4 — bucket summaries (default: Gemini Flash)
OMEGA_PHASE4_BACKEND=gemini
OMEGA_PHASE4_MODEL=gemini-2.5-flash-lite
OMEGA_PHASE4_MAX_INPUT_CHARS=48000

# Optional: Phase 2–4 DB paths default to logs/phase2.db when unset
