OMEGA_EMBEDDING_BACKEND=gemini
OMEGA_GEMINI_API_KEY=your_gemini_api_key_here
# Stable, cost-efficient text embeddings (Google AI Gemini API)
OMEGA_EMBED_MODEL=gemini-embedding-001
# OMEGA_GEMINI_BASE_URL=https://generativelanguage.googleapis.com

# Phase 4 — real summaries use Gemini by default (requires OMEGA_GEMINI_API_KEY above).
# Uncomment to override defaults; use OMEGA_PHASE4_BACKEND=stub only for offline/CI (not real LLM output).
# OMEGA_PHASE4_BACKEND=gemini
# OMEGA_PHASE4_MODEL=gemini-2.5-flash-lite
# OMEGA_PHASE4_MAX_INPUT_CHARS=48000
