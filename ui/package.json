{
  "name": "omega-session-ui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --port 5174 --strictPort",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "build:rust": "cd .. && cargo build --bin omega-api --bin sensor_layer",
    "electron": "npx electron .",
    "electron:dev": "npm run build:rust && npx concurrently -k \"npm run dev\" \"npx wait-on http://127.0.0.1:5174 && npx electron .\"",
    "start": "npm run build && npm run build:rust && npx electron ."
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.1.2",
    "electron": "^34.0.0",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "wait-on": "^8.0.1"
  }
}
